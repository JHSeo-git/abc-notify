# abc-notify configuration
# Copy to ~/.abc-notify.env (global) or ./.abc-notify.env (per-project)

# Terminal app name(s), comma-separated (used for focus detection and activation)
# Shared fallback: auto-detected from TERM_PROGRAM if not set
# Codex also has extra bundle detection for click-to-activate
# Single:   TERMINAL_APP=iTerm2
# Multiple: TERMINAL_APP=iTerm2,Terminal,WezTerm
# TERMINAL_APP=iTerm2

# Notification sound (macOS system sound name)
# NOTIFY_SOUND=Glass

# Custom notification titles
# NOTIFY_TITLE_CLAUDE="Claude Code"
# NOTIFY_TITLE_CODEX="Codex"

# Throttle interval in seconds (prevents duplicate notifications)
# NOTIFY_THROTTLE=2

# Disable notifications (set to true to suppress all notifications)
# NOTIFY_DISABLED=false
